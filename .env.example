# CoverBounty Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# Database
# ============================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
# Providers: Supabase, Neon, Railway, or self-hosted
DATABASE_URL=postgresql://user:password@localhost:5432/coverbounty

# Redis connection string
# Format: redis://[:password@]host[:port][/db-number]
# Providers: Upstash, Railway, or self-hosted
REDIS_URL=redis://localhost:6379

# ============================================================
# Stripe
# ============================================================

# Found at: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_...) for development
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key - NEVER expose this client-side
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret for verifying Stripe events
# Get from: https://dashboard.stripe.com/webhooks
# Or use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# App
# ============================================================

# Public URL of the deployed app (no trailing slash)
# Used for QR code generation, share links, and webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.io server URL (can be same as app URL for combined deployment)
# If running separate Socket.io server, set this to that URL
SOCKET_IO_URL=http://localhost:3000

# ============================================================
# Optional: Authentication
# ============================================================

# JWT secret for session signing (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here

# ============================================================
# Optional: External Music APIs
# ============================================================

# Bandsintown API for show sync
# BANDSINTOWN_API_KEY=

# Songkick API for show sync
# SONGKICK_API_KEY=
