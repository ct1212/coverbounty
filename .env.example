# CoverBounty Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# Database
# ============================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
# Providers: Supabase, Neon, Railway, or self-hosted
DATABASE_URL="postgresql://user:password@localhost:5432/coverbounty"
DIRECT_URL="postgresql://user:password@localhost:5432/coverbounty"

# Redis connection string (optional - Socket.io falls back to in-memory if not set)
# Format: redis://[:password@]host[:port][/db-number]
# Providers: Upstash, Railway, or self-hosted
REDIS_URL="redis://localhost:6379"

# ============================================================
# Stripe
# ============================================================

# Get your keys from https://dashboard.stripe.com/apikeys
# Use test keys for development (pk_test_..., sk_test_...)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret for Stripe Connect events
# Get this from `stripe listen --forward-to localhost:3000/api/webhooks` or dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================
# App Configuration
# ============================================================

# Base URL of your app (used for QR code generation, share links, CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket.io server URL (usually same as app URL)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Server port (defaults to 3000)
PORT=3000

# Cron job authentication secret (for /api/cron/* endpoints)
CRON_SECRET="your-secret-cron-key-min-32-chars-long"

# JWT secret for auth (if implementing fan accounts)
JWT_SECRET="your-jwt-secret-min-32-characters-long"
