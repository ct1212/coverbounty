# Database (PostgreSQL via Supabase or local)
DATABASE_URL="postgresql://user:password@localhost:5432/coverbounty"
DIRECT_URL="postgresql://user:password@localhost:5432/coverbounty"

# Stripe (use test keys for development)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Redis (optional - Socket.io falls back to in-memory if not set)
REDIS_URL="redis://localhost:6379"

# App URL (used for QR code generation and CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket.io URL (used by frontend)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Cron job authentication
CRON_SECRET="your-secret-cron-key"

# Server port (defaults to 3000)
PORT=3000
