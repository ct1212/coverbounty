# Local development overrides
# Copy this to .env.local — this file is gitignored

# Database (Neon recommended for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coverbounty_dev
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/coverbounty_dev

# Redis (optional, for Socket.io horizontal scaling)
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=dev-secret-change-in-production-min-32-chars

# Cron auth
CRON_SECRET=dev-cron-secret
